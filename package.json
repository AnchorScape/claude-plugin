{
  "name": "@anchorscape/claude-plugin",
  "version": "1.0.0",
  "description": "Scan, fix, and deploy your code from Claude Code",
  "type": "module",
  "main": "dist/bundle.cjs",
  "bin": {
    "anchorscape-mcp": "dist/bundle.cjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs",
    "build:tsc": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "security",
    "deploy",
    "anchorscape"
  ],
  "author": "Anchorscape",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnchorScape/claude-plugin.git"
  },
  "homepage": "https://anchorscape.com",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "dist/",
    "skills/",
    ".claude-plugin/",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ]
}
